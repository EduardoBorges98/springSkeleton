# ============================================================
#  .env.example
#  Copie para .env e preencha os valores reais.
#  NUNCA commite o .env no repositório.
# ============================================================

# ── Aplicação ──────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080

# ── Banco de dados ─────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/skeleton_db
DB_USER=postgres
DB_PASS=postgres

# ── Redis ──────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ────────────────────────────────────────────────────
# Gere com: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_USE_AT_LEAST_256_BITS_BASE64_ENCODED_STRING
JWT_EXPIRATION=86400000
JWT_REFRESH=604800000

# ── CORS ───────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:4200
